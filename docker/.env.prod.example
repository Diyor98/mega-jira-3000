# Database
DB_USER=mega
DB_PASSWORD=CHANGE_ME_strong_password_here
DB_NAME=mega_prod

# Redis
REDIS_PASSWORD=CHANGE_ME_redis_password_here

# JWT
JWT_SECRET=CHANGE_ME_min_16_chars_random_string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Ports (host-side)
API_PORT=3001
WEB_PORT=3000

# URLs — update these to match your EC2 public IP or domain
# NEXT_PUBLIC_API_URL is baked into the frontend at build time
NEXT_PUBLIC_API_URL=http://YOUR_EC2_PUBLIC_IP:3001/api/v1

# WEB_URL is used by the API for CORS origin
WEB_URL=http://YOUR_EC2_PUBLIC_IP:3000
